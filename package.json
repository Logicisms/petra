{
  "name": "petra-sass",
  "version": "2.0.0",
  "description": "A configurable, responsive, slightly experimental Sass/SCSS framework.",
  "scripts": {
    "test": "nps stylelint",
    "clean": "nps clean",
    "build:sass": "nps sass",
    "build:html": "nps html",
    "prebuild": "npm test && nps clean",
    "build": "parallelshell \"npm run build:sass\" \"npm run build:html\"",
    "watch:sass": "nps watch.sass",
    "watch:html": "nps watch.html",
    "watch": "parallelshell \"npm run watch:sass\" \"npm run watch:html\"",
    "server": "nps server",
    "prestart": "npm run build",
    "start": "parallelshell \"npm run server\" \"npm run watch:sass\" \"npm run watch:html\"",
    "start:no-server": "npm run build && npm run watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Logicisms/petra.git"
  },
  "bugs": {
    "url": "https://github.com/Logicisms/petra/issues"
  },
  "files": [
    "petra/**/*.scss",
    "_petra.scss",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "author": "Jean-Luc Harbin <jeanluc.harbin@gmail.com>",
  "license": "MIT",
  "keywords": [
    "BEM",
    "CSS reset",
    "flexbox",
    "framework",
    "grid",
    "inverted triangle",
    "ITCSS",
    "Sass",
    "SCSS"
  ],
  "homepage": "https://github.com/Logicisms/petra#readme",
  "dependencies": {
    "sass-less-material-colors": "^1.1.0"
  },
  "devDependencies": {
    "autoprefixer": "^9.5.0",
    "copy": "^0.3.2",
    "cssnano": "^4.1.10",
    "http-server": "^0.11.1",
    "node-sass": "^4.11.0",
    "npm-run-all": "^4.1.5",
    "nps": "^5.9.5",
    "onchange": "^5.2.0",
    "parallelshell": "3.0.1",
    "postcss-cli": "^6.1.2",
    "rimraf": "^2.6.3",
    "stylelint": "^9.10.1"
  }
}
